# --- AI provider selection ---
# "anthropic" (default, Claude Haiku 4.5) or "gemini" (Google Gemini 2.5 Flash, free tier).
# Flip to "gemini" if Anthropic has an outage or you want to test on the free tier.
AI_PROVIDER=anthropic

# --- Anthropic (Claude Haiku 4.5 for connective tissue + auto-titles) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Google Gemini (fallback) ---
# Free key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Supabase (auth + warrens/nodes/edges persistence) ---
# New key format (Project Settings → API Keys):
#   publishable key (sb_publishable_…) — client-safe, RLS-bound
#   secret key      (sb_secret_…)      — server-only, bypasses RLS for anon-author writes
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# --- Wikimedia REST API ---
# Required by Wikimedia: see https://meta.wikimedia.org/wiki/User-Agent_policy
# Format: <product>/<version> (<contact>)
WIKIPEDIA_USER_AGENT=Warren/0.1 (https://warren.app; team@warren.app)

# --- Upstash Redis (cache for Wikipedia summaries + AI bridge pairs) ---
# Optional: leave blank and caching is a no-op (dev still works, just no cache).
# Create a free DB at https://console.upstash.com and copy the REST creds.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- App ---
# Base URL used for OG image absolute URLs in dev/preview/prod.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Browser extension bridge (optional) ---
# Shared secret the Warren browser extension sends to POST /api/extension/hop.
# Generate any random string; paste the same value into the extension popup.
# When unset, the extension write bridge is disabled.
WARREN_EXTENSION_TOKEN=
